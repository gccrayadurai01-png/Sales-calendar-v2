# Copy this file to backend/.env and fill in your HubSpot token
# To get your token:
# 1. Go to HubSpot → Settings → Integrations → Private Apps
# 2. Create a new private app with scopes: crm.objects.deals.read, crm.objects.owners.read
# 3. Copy the Access Token below

HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here
PORT=3001

# Optional production (e.g. Render persistent disk mounted at /var/data)
# SQLITE_DB_PATH=/var/data/sales-calendar.db
